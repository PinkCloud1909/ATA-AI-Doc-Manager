# ─── Backend ──────────────────────────────────────────────────────────────────
# URL của FastAPI backend (Cloud Run service URL hoặc localhost khi dev)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# URL nội bộ Next.js dùng để proxy rewrites (server-side)
BACKEND_URL=http://localhost:8000

# ─── Google Cloud ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1

# Google Cloud Storage
# Tên bucket lưu trữ file tài liệu (docx, pdf)
GCS_BUCKET_NAME=runbook-documents
# Base URL công khai của bucket (nếu bucket là public)
NEXT_PUBLIC_GCS_BASE_URL=https://storage.googleapis.com/runbook-documents

# ─── Firebase (Authentication) ────────────────────────────────────────────────
# Dùng Firebase Auth để xác thực người dùng và lấy Google ID Token
# ID Token sẽ được backend FastAPI verify qua Google IAM
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-gcp-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── WebSocket ────────────────────────────────────────────────────────────────
# Endpoint WebSocket cho Chat streaming
# (thường là wss:// trên production Cloud Run)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1
