# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Document Manager

# Backend
APP_NAME=dms-backend
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=dms_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/dms_backend
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/dms_backend


# JWT
JWT_SECRET_KEY=change-me-in-real-environments
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=documents
MINIO_PRESIGNED_EXPIRY_MINUTES=15

# Seed defaults
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_ROLE_NAME=admin
DEFAULT_USER_ROLE_NAME=user

# --- GCP / Vertex AI (Production) ---
# ENVIRONMENT controls adapter selection ("production" or "prod").
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
# Required for Vertex AI mode.  Without this, ADK agents will try to use
# Gemini API (GOOGLE_API_KEY) instead of Vertex AI even when GCP_PROJECT_ID is set.
# GOOGLE_GENAI_USE_VERTEXAI=True
GCS_BUCKET_NAME=documents
GCS_PRESIGNED_EXPIRY_MINUTES=15

# --- Cloud SQL (Cloud Run production only) ---
# Set CLOUD_SQL_CONNECTION_NAME to enable Unix-socket mode.
# Format: PROJECT_ID:REGION:INSTANCE_NAME
# Leave empty for local Docker Compose.
CLOUD_SQL_CONNECTION_NAME=
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dms_backend

# --- Cloud Tasks + Worker Security (Cloud Run production only) ---
# When CLOUD_TASKS_QUEUE_NAME and WORKER_SERVICE_URL are set AND
# ENVIRONMENT=production, document approval enqueues an async Cloud Tasks
# HTTP task instead of vectorizing synchronously.
# Leave all empty for local Docker Compose.
#
# Security model: Cloud Tasks attaches a Google-signed OIDC ID token in the
# Authorization header.  The worker endpoint verifies the token signature and
# checks that the `email` claim matches CLOUD_RUN_SA_EMAIL.
# Required IAM:
#   gcloud run services add-iam-policy-binding <service-name> \
#     --member="serviceAccount:${CLOUD_RUN_SA_EMAIL}" \
#     --role="roles/run.invoker"
CLOUD_TASKS_QUEUE_NAME=
CLOUD_TASKS_LOCATION=us-central1
# The public HTTPS URL of this Cloud Run service (no trailing slash).
# Example: https://dms-backend-abc123-uc.a.run.app
WORKER_SERVICE_URL=
# Service account email Cloud Tasks uses to generate the OIDC token.
# Must have roles/run.invoker on this Cloud Run service.
# Example: cloud-tasks-sa@my-project.iam.gserviceaccount.com
CLOUD_RUN_SA_EMAIL=

# --- Vectorization ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=gemini-embedding-2
LLM_MODEL=gemini-3.1-flash-lite
