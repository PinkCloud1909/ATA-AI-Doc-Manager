# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Document Manager

# Backend
APP_NAME=dms-backend
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=dms_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/dms_backend

# JWT
JWT_SECRET_KEY=change-me-in-real-environments
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=documents
MINIO_PRESIGNED_EXPIRY_MINUTES=15

# Seed defaults
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_ROLE_NAME=admin
DEFAULT_USER_ROLE_NAME=user

# --- GCP / Vertex AI (Production) ---
# ENVIRONMENT controls adapter selection ("production" or "prod").
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCS_BUCKET_NAME=documents
GCS_PRESIGNED_EXPIRY_MINUTES=15
VERTEX_INDEX_ID=
VERTEX_INDEX_ENDPOINT_ID=
VERTEX_DEPLOYED_INDEX_ID=

# --- Cloud SQL (Cloud Run production only) ---
# Set CLOUD_SQL_CONNECTION_NAME to enable Unix-socket mode.
# Format: PROJECT_ID:REGION:INSTANCE_NAME
# Leave empty for local Docker Compose.
CLOUD_SQL_CONNECTION_NAME=
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dms_backend
