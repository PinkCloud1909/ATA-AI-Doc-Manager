# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Document Manager
NEXT_PUBLIC_USE_MOCK=true
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1

# Firebase (Frontend Auth)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Backend
APP_NAME=dms-backend
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO

# GCP / Cloud Run
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1

# Cloud SQL (PostgreSQL)
# Use connector on Cloud Run by setting USE_CLOUD_SQL_CONNECTOR=true
USE_CLOUD_SQL_CONNECTOR=false
CLOUD_SQL_CONNECTION_NAME=project:region:instance
CLOUD_SQL_DB_USER=postgres
CLOUD_SQL_DB_PASSWORD=postgres
CLOUD_SQL_DB_NAME=dms_backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dms_backend

# Local PostgreSQL (docker-compose)
POSTGRES_DB=dms_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT
JWT_SECRET_KEY=change-me-in-real-environments
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Cloud Storage
GCS_BUCKET=documents
GCS_BUCKET_NAME=documents
NEXT_PUBLIC_GCS_BASE_URL=https://storage.googleapis.com/documents
GCS_SIGNED_URL_EXPIRY_MINUTES=15

# Vertex AI
VERTEX_AI_LOCATION=asia-southeast1
VERTEX_AI_ENDPOINT=
VERTEX_AI_INDEX_ENDPOINT_ID=
VERTEX_AI_INDEX_ID=

# Seed defaults
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_ROLE_NAME=admin
DEFAULT_USER_ROLE_NAME=user
