# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1

# ── Cloud SQL ─────────────────────────────────────────────────────────────────
# Local dev: để trống, dùng DATABASE_URL trực tiếp
CLOUD_SQL_INSTANCE=
DATABASE_URL=postgresql+asyncpg://runbook:runbook@localhost:5432/runbook_db
DB_USER=runbook
DB_PASSWORD=runbook
DB_NAME=runbook_db

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-gcp-project-id

# ── Vertex AI ─────────────────────────────────────────────────────────────────
VERTEX_AI_LOCATION=asia-southeast1
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MODEL_FLASH=gemini-1.5-flash

# Vertex AI Vector Search (tạo trong GCP Console → Vertex AI → Vector Search)
VECTOR_SEARCH_INDEX_ID=projects/YOUR_PROJECT/locations/asia-southeast1/indexes/YOUR_INDEX_ID
VECTOR_SEARCH_INDEX_ENDPOINT=projects/YOUR_PROJECT/locations/asia-southeast1/indexEndpoints/YOUR_ENDPOINT_ID
VECTOR_SEARCH_TOP_K=5
VECTOR_SEARCH_DISTANCE_THRESHOLD=0.7

# ── GCS ───────────────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=runbook-documents
GCS_SIGNED_URL_TTL=900

# ── CORS ──────────────────────────────────────────────────────────────────────
# Thêm FE Cloud Run URL khi deploy
ALLOWED_ORIGINS=["http://localhost:3000"]
