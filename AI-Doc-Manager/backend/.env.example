APP_NAME=dms-backend
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO

POSTGRES_DB=dms_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/dms_backend
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/dms_backend
GOOGLE_API_KEY=your_api_key_here

# --- Security ---
# IMPORTANT: Replace with a strong random secret (>= 32 chars) before deploying to production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-real-environments
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# For production, set this to your actual frontend domain(s), e.g.:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- MinIO (Object Storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=documents
MINIO_PRESIGNED_EXPIRY_MINUTES=15
# Maximum file upload size in megabytes.
MAX_UPLOAD_SIZE_MB=50

# --- Admin seed user ---
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_ROLE_NAME=admin
DEFAULT_USER_ROLE_NAME=user

# --- Vectorization ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=20

# --- ChromaDB ---
# Leave CHROMA_HOST empty to use the local PersistentClient (default for Docker).
# Set CHROMA_HOST=chromadb if running ChromaDB as a separate container.
CHROMA_HOST=
CHROMA_PORT=8001
CHROMA_COLLECTION=document_chunks
# Path where ChromaDB persists its data on disk.
# In Docker this must match the volume mount in docker-compose.yml.
CHROMA_PERSIST_PATH=/app/.chroma_data
