APP_NAME=dms-backend
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO

POSTGRES_DB=dms_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/dms_backend

JWT_SECRET_KEY=change-me-in-real-environments
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=documents
MINIO_PRESIGNED_EXPIRY_MINUTES=15

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_ROLE_NAME=admin
DEFAULT_USER_ROLE_NAME=user
