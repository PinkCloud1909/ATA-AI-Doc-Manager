APP_NAME=dms-backend
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO

POSTGRES_DB=dms_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# DATABASE_URL (sync) and ASYNC_DATABASE_URL (async, used by chat session store)
# In production:
# - If CLOUD_SQL_CONNECTION_NAME is set, both are overridden dynamically by Unix sockets.
# - If not using Cloud SQL sockets, these MUST point to remote databases (fail-fast checks reject localhost/127.0.0.1).
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/dms_backend
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/dms_backend
GOOGLE_API_KEY=your_api_key_here

# --- ADK Agent Model Routing ---
# ADK agents (QA chat, runbook generation) resolve model auth from the environment.
# For local development with Gemini API (AI Studio), set GOOGLE_API_KEY above and
# leave GOOGLE_GENAI_USE_VERTEXAI commented out.
# For Vertex AI (production), set these AND GOOGLE_GENAI_USE_VERTEXAI=True.
# GOOGLE_GENAI_USE_VERTEXAI=True

# --- Security ---
# IMPORTANT: Replace with a strong random secret (>= 32 chars) before deploying to production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-real-environments
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# JSON list of allowed frontend origins.
# For production, set this to your actual frontend domain(s), e.g.:
# CORS_ALLOWED_ORIGINS=["https://app.example.com","https://www.example.com"]
# The field validator also accepts comma-separated strings at runtime,
# but the .env file must use JSON format for pydantic-settings to parse correctly.
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Maximum file upload size in megabytes.
MAX_UPLOAD_SIZE_MB=50

# --- Admin seed user ---
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_ROLE_NAME=admin
DEFAULT_USER_ROLE_NAME=user

# --- GCP / Cloud Storage (required for all environments) ---
# Local dev uses Application Default Credentials (ADC).  Run:
#   gcloud auth application-default login
# The docker-compose mounts your host ADC file into the API container.
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCS_BUCKET_NAME=documents
GCS_PRESIGNED_EXPIRY_MINUTES=15

# --- Cloud SQL (Cloud Run production only) ---
# Set CLOUD_SQL_CONNECTION_NAME to activate Unix-socket mode.
# Format: PROJECT_ID:REGION:INSTANCE_NAME
# Leave empty for local Docker Compose (DATABASE_URL is used instead).
CLOUD_SQL_CONNECTION_NAME=
# Set to true when Cloud Run connects via VPC (private IP) instead of public IP.
CLOUD_SQL_USE_PRIVATE_IP=false
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dms_backend

# --- Cloud Tasks (Cloud Run production async ingestion) ---
# When CLOUD_TASKS_QUEUE_NAME is set AND ENVIRONMENT=production, RAG ingestion
# requests are enqueued and return 202 immediately instead of running in-request.
# Leave all three empty for local Docker Compose (synchronous mode is used).
CLOUD_TASKS_QUEUE_NAME=
CLOUD_TASKS_LOCATION=us-central1
# Full URL of the backend Cloud Run service (used as the task HTTP target).
# Example: https://dms-backend-abc123-uc.a.run.app
WORKER_SERVICE_URL=
# Service account email for OIDC token generation.
# Must have roles/run.invoker on the backend Cloud Run service.
CLOUD_RUN_SA_EMAIL=

LLM_MODEL=gemini-2.5-flash

# --- RAG Engine (Vertex AI Managed RAG) ---
# RAG Engine corpus resource name (auto-created if empty).
# Format: projects/{PROJECT_ID}/locations/{LOCATION}/ragCorpora/{CORPUS_ID}
RAG_CORPUS_RESOURCE=
# RAG Engine location (defaults to GCP_LOCATION).
# Must be us-central1 for serverless mode.
RAG_ENGINE_LOCATION=
# Embedding model for RAG corpus (fixed at corpus creation).
RAG_EMBEDDING_MODEL=text-embedding-005
# Chunking settings for RAG Engine import (server-side).
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=256
# Enable Document AI Layout Parser for improved PDF/DOCX chunking.
RAG_LAYOUT_PARSER_ENABLED=false
# Document AI Layout Parser processor resource name (required when enabled).
# Format: projects/{PROJECT_ID}/locations/{LOCATION}/processors/{PROCESSOR_ID}
# RAG_LAYOUT_PARSER_PROCESSOR_NAME=projects/my-project/locations/us/processors/abc123
# Max parsing requests per minute for the layout parser.
RAG_LAYOUT_PARSER_MAX_PARSING_RPM=120
# Optional LLM model for parsing images/scanned docs.
# Example: gemini-2.5-flash. Leave empty for the default parser.
RAG_LLM_PARSER_MODEL=
# Max embedding RPM during import (1-1500).
RAG_MAX_EMBEDDING_REQUESTS_PER_MIN=1000
# Cosine distance threshold for retrieval (0-2). Lower = stricter matching.
RAG_RETRIEVAL_DISTANCE_THRESHOLD=0.5
# Max time (seconds) to wait for import_files() to complete.
RAG_IMPORT_TIMEOUT_SECONDS=600
# Optional GCS prefix for per-file import result NDJSON files.
# A unique suffix (document-id + uuid) is appended per import.
# RAG_IMPORT_RESULT_SINK=gs://your-bucket/import_results
