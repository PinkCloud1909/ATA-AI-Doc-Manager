# Environment files — never ship secrets to the image
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Tests — not needed at runtime
tests/
app/tests/
pytest-cache-files-*
**/pytest-cache-files-*

# Git
.git/
.gitignore
.gitattributes

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Development artifacts
*.patch
